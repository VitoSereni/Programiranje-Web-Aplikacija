<?php

$odgovor = "";
$zamisljeniBroj = "";

if (isset($_POST["broj"])) {

    $korisnikBroj = $_POST["broj"];
    $zamisljeniBroj = rand(1, 9);

    if ($korisnikBroj == $zamisljeniBroj) {
        $odgovor = "<p style='color:green;'>Pogodak, probaj ponovo!</p>";
    }
    else {
        $odgovor = "<p style='color:red;'>Krivo, probaj ponovo!</p>";
    }
}
?>

