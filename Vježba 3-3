<?php

$prosjek = "";
$konacnaOcjena = "";

if (isset($_POST["kol1"]) && isset($_POST["kol2"])) {

    $kol1 = $_POST["kol1"];
    $kol2 = $_POST["kol2"];

    if ($kol1 < 1 || $kol1 > 5 || $kol2 < 1 || $kol2 > 5) {

        $konacnaOcjena = "Ocjene moraju biti između 1 i 5.";

    } else {

        $prosjek = ($kol1 + $kol2) / 2;

        if ($kol1 == 1 || $kol2 == 1) {
            $konacnaOcjena = 1;
        } else {
            $konacnaOcjena = round($prosjek);
        }

    }
}

?>

